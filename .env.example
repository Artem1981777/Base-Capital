# --- Base Capital config ---

# testnet (Base Sepolia, free, no keys) or mainnet (real rewards)
NETWORK_MODE=testnet

# USDC payout / identity. Basename resolves to your payout address.
PAY_TO=artem00777.base.eth

# Base Builder Code (ERC-8021 attribution -> Builder Rewards)
BUILDER_CODE=bc_kob8hqa0

# Price per /v1/risk call, in USDC
RISK_PRICE_USD=0.01

# Optional custom RPC (defaults: mainnet.base.org / sepolia.base.org)
# RPC_URL=

# Mainnet uses the keyless xpay facilitator (https://facilitator.xpay.sh) — no keys needed.

PORT=3000
